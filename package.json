{
  "name": "gators-gametracker-cloud",
  "version": "1.0.0",
  "description": "Live Gators score + inning from the Texas League schedule, with push alerts. Single-file, fits a free host.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "report:season": "node scripts/season-report.js",
    "report:game": "node scripts/postgame-report.js",
    "report:pdf": "node scripts/postgame-report.js latest --pdf",
    "report:box": "node scripts/box-score.js latest --pdf"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "nodemailer": "^6.9.14",
    "web-push": "^3.6.7"
  }
}
